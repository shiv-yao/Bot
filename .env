}
REAL_TRADING=true

# ⚠️ 你的私鑰（64-byte array）
PRIVATE_KEY_JSON=[12,34,56,...]

# RPC（建議用付費）
SOLANA_RPC_HTTP=https://api.mainnet-beta.solana.com
SOLANA_RPC_WS=wss://api.mainnet-beta.solana.com

# Jupiter
JUP_API_KEY=https://lite-api.jup.ag

# Jito（可先關）
USE_JITO=false
JITO_BUNDLE_URL=

# 風控
MAX_POSITION_SOL=0.0025
MIN_POSITION_SOL=0.001
MAX_POSITIONS
